# Local Configuration
# Copy this file to local.properties and update with your values
# local.properties is in .gitignore and won't be committed

## Signaling Server URL
# For Android emulator connecting to localhost server, use: http://10.0.2.2:3000
# For real device on same network, use your computer's IP: http://192.168.x.x:3000
# For production server, use: https://your-server.com
signaling.url=http://10.0.2.2:3000

## SDK Location (if needed)
# Uncomment and set if Android Studio doesn't auto-detect
# sdk.dir=/Users/username/Library/Android/sdk