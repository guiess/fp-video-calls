rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — any authenticated user can read (for contact search),
    // only the owner can write.
    match /users/{userId} {
      allow read: if request.auth != null;
      // Only the owner can write, and sensitive fields must not be in the public doc
      allow write: if request.auth != null && request.auth.uid == userId
                   && !("fcmToken" in request.resource.data)
                   && !("email" in request.resource.data);

      // Private subcollection — only owner reads/writes, server uses Admin SDK
      match /private/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Contacts subcollection — private to the owner
      match /contacts/{contactId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Call history subcollection — private to the owner
      match /callHistory/{callId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Saved groups subcollection — private to the owner
      match /groups/{groupId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Recent groups subcollection — private to the owner
      match /recentGroups/{groupId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Room history subcollection — private to the owner
      match /recentRooms/{roomDocId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Location current — owner writes, shared contacts can read
      match /location/{docId} {
        allow write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null;
      }

      // Location history — owner writes, shared contacts can read
      match /locationHistory/{docId} {
        allow write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null;
      }

      // Admin-only subcollection — server uses Admin SDK, clients denied
      match /admin/{docId} {
        allow read, write: if false;
      }
    }
  }
}
